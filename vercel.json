{
  "version": 2,
  "routes": [
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(flutter_bootstrap\\.js|main\\.dart\\.js|flutter\\.js|flutter_service_worker\\.js|manifest\\.json)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/(.+\\.(wasm|css|png|jpg|jpeg|gif|ico|svg|ttf|woff|woff2))",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
